# ─── Supabase ───────────────────────────────────────────
# URL del proyecto (Settings → API)
SUPABASE_URL=https://dlqnrlenosemcsfyhltc.supabase.co

# SERVICE ROLE key — NO la anon key (Settings → API → service_role)
# Esta key bypasea RLS. Nunca la expongas en el frontend.
SUPABASE_SERVICE_KEY=eyJhb...

# ─── Twitter / X Developer ──────────────────────────────
# developer.twitter.com → tu app → "Keys and tokens"
# Necesitas plan FREE (o Basic). El free permite 1.500 tweets/mes.
TWITTER_API_KEY=xxxx
TWITTER_API_SECRET=xxxx
TWITTER_ACCESS_TOKEN=xxxx-xxxx
TWITTER_ACCESS_SECRET=xxxx

# ─── Anthropic / Claude ─────────────────────────────────
# console.anthropic.com → API Keys
# Claude Haiku: ~€0.001 por tweet generado
ANTHROPIC_API_KEY=sk-ant-...

# ─── Opcional ───────────────────────────────────────────
# Pon "true" para probar sin publicar nada en Twitter
DRY_RUN=false
